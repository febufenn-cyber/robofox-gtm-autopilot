{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robofox.local/schemas/experiment-definition.schema.json",
  "title": "experiment-definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["version","id","product","decision_id","decision_record_hash","candidate_id","candidate_hash","snapshot_hash","decision_status","hypothesis","target_segment","audience_key","change_dimensions","primary_metric","secondary_metrics","minimum_execution","maximum_exposure","planned_start","planned_end","success_criteria","kill_criteria","hard_stop_conditions","owner","collision_waiver","sensitivity","registered_at"],
  "properties": {
    "version": {"const": 1},
    "id": {"type": "string", "pattern": "^EXP-"},
    "product": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "decision_id": {"type": "string", "pattern": "^DEC-"},
    "decision_record_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "candidate_id": {"type": "string", "pattern": "^MOV-"},
    "candidate_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "snapshot_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "decision_status": {"const": "CHOSEN"},
    "hypothesis": {"type": "string", "minLength": 10},
    "target_segment": {"type": "string", "minLength": 3},
    "audience_key": {"type": "string", "minLength": 3},
    "change_dimensions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["SEGMENT","OFFER","MESSAGE","PRICE","CHANNEL","PRODUCT","ONBOARDING","SALES_PROCESS"]}},
    "primary_metric": {"type": "string", "minLength": 2},
    "secondary_metrics": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "minimum_execution": {"type": "object", "additionalProperties": false, "required": ["unit","target"], "properties": {"unit": {"type": "string"}, "target": {"type": "integer", "minimum": 1}}},
    "maximum_exposure": {"type": "object", "additionalProperties": false, "required": ["cash_usd","founder_hours","days_to_signal"], "properties": {"cash_usd": {"type": "number", "minimum": 0}, "founder_hours": {"type": "number", "minimum": 0}, "days_to_signal": {"type": "integer", "minimum": 1}}},
    "planned_start": {"type": "string", "format": "date-time"},
    "planned_end": {"type": "string", "format": "date-time"},
    "success_criteria": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["metric","operator","threshold","unit","minimum_sample_size"], "properties": {"metric": {"type": "string", "minLength": 2}, "operator": {"enum": ["GTE","LTE","GT","LT","EQ"]}, "threshold": {"type": "number"}, "unit": {"type": "string", "minLength": 1}, "minimum_sample_size": {"type": "integer", "minimum": 0}}}},
    "kill_criteria": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["metric","operator","threshold","unit","minimum_sample_size"], "properties": {"metric": {"type": "string", "minLength": 2}, "operator": {"enum": ["GTE","LTE","GT","LT","EQ"]}, "threshold": {"type": "number"}, "unit": {"type": "string", "minLength": 1}, "minimum_sample_size": {"type": "integer", "minimum": 0}}}},
    "hard_stop_conditions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "owner": {"type": "string", "minLength": 2},
    "collision_waiver": {"oneOf": [{"type": "null"},{"type": "object", "additionalProperties": false, "required": ["conflicting_experiment_ids","reason","isolation_plan"], "properties": {"conflicting_experiment_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^EXP-"}}, "reason": {"type": "string", "minLength": 10}, "isolation_plan": {"type": "string", "minLength": 10}}}]},
    "sensitivity": {"enum": ["INTERNAL","CONFIDENTIAL"]},
    "registered_at": {"type": "string", "format": "date-time"}
  }
}
