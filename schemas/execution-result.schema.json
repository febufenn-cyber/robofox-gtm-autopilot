{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "pattern": "^XRS-[A-Z0-9-]{6,80}$"},
    "envelope_id": {"type": "string", "pattern": "^EXR-[A-Z0-9-]{6,80}$"},
    "outcome": {"enum": ["SUCCESS", "PARTIAL", "FAILURE", "AMBIGUOUS"]},
    "affected_records": {"type": "integer", "minimum": 0},
    "spend_usd": {"const": 0},
    "external_reference": {"type": "null"},
    "reversible": {"type": "boolean"},
    "completed_at": {"type": "string", "format": "date-time"},
    "details": {"type": "object"}
  },
  "required": ["id", "envelope_id", "outcome", "affected_records", "spend_usd", "external_reference", "reversible", "completed_at", "details"]
}
