{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robofox.local/schemas/contactability.schema.json",
  "title": "Robofox GTM Channel Contactability",
  "type": "object",
  "additionalProperties": false,
  "required": ["contact_id", "channels", "global_suppression"],
  "properties": {
    "contact_id": {"type": "string", "minLength": 1},
    "channels": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "email": {"$ref": "#/$defs/channelStatus"},
        "whatsapp": {"$ref": "#/$defs/channelStatus"},
        "phone": {"$ref": "#/$defs/channelStatus"}
      }
    },
    "global_suppression": {"type": "boolean"},
    "suppression_reason": {"type": ["string", "null"]}
  },
  "$defs": {
    "channelStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {"enum": ["unknown", "not_requested", "opted_in", "opted_out", "do_not_contact", "expired", "legitimate_existing_relationship", "requires_manual_review"]},
        "captured_at": {"type": ["string", "null"], "format": "date-time"},
        "source": {"type": ["string", "null"]}
      }
    }
  }
}
