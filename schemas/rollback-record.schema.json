{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "pattern": "^XRB-[A-Z0-9-]{6,80}$"},
    "envelope_id": {"type": "string", "pattern": "^EXR-[A-Z0-9-]{6,80}$"},
    "result_id": {"type": "string", "pattern": "^XRS-[A-Z0-9-]{6,80}$"},
    "outcome": {"enum": ["ROLLED_BACK", "ROLLBACK_FAILED"]},
    "occurred_at": {"type": "string", "format": "date-time"},
    "details": {"type": "object"}
  },
  "required": ["id", "envelope_id", "result_id", "outcome", "occurred_at", "details"]
}
