{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "pattern": "^EXR-[A-Z0-9-]{6,80}$"},
    "experiment_id": {"type": "string", "pattern": "^EXP-[A-Z0-9-]{6,80}$"},
    "action_type": {"enum": ["PREPARE_CRM_TASK", "SEND_EMAIL", "SEND_WHATSAPP", "PLACE_PHONE_CALL", "PUBLISH_CONTENT", "CHANGE_META_CAMPAIGN"]},
    "adapter": {"enum": ["internal.crm_task", "email", "whatsapp", "phone", "publish", "meta_ads"]},
    "mode": {"const": "SIMULATOR"},
    "idempotency_key": {"type": "string", "minLength": 16, "maxLength": 160},
    "target_keys": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^TGT-[A-Z0-9-]{6,80}$"}},
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "payload": {"type": "object"},
    "batch_size": {"type": "integer", "minimum": 1, "maximum": 10},
    "canary_for_id": {"type": ["string", "null"], "pattern": "^EXR-[A-Z0-9-]{6,80}$"},
    "maximum_spend_usd": {"const": 0},
    "currency": {"const": "USD"},
    "rate_limit_per_hour": {"type": "integer", "minimum": 1, "maximum": 20},
    "rollback_plan": {"type": "object", "additionalProperties": false, "properties": {"required": {"type": "boolean"}, "strategy": {"type": "string", "minLength": 3}, "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600}}, "required": ["required", "strategy", "timeout_seconds"]},
    "created_at": {"type": "string", "format": "date-time"},
    "sensitivity": {"enum": ["INTERNAL", "CONFIDENTIAL"]}
  },
  "required": ["id", "experiment_id", "action_type", "adapter", "mode", "idempotency_key", "target_keys", "content_hash", "payload", "batch_size", "canary_for_id", "maximum_spend_usd", "currency", "rate_limit_per_hour", "rollback_plan", "created_at", "sensitivity"]
}
