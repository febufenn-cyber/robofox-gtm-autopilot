{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "approval_id": {"type": "string", "pattern": "^APR-[0-9]{4}-[0-9]{5,}$"},
    "action_id": {"type": "string", "pattern": "^ACT-[0-9]{4}-[0-9]{5,}$"},
    "manifest_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "approved_by": {"type": "string", "minLength": 1},
    "approved_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "single_use": {"const": true},
    "consumed_at": {"type": "null"}
  },
  "required": ["approval_id", "action_id", "manifest_hash", "approved_by", "approved_at", "expires_at", "single_use", "consumed_at"]
}
