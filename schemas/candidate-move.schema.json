{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robofox.local/schemas/candidate-move.schema.json",
  "title": "Robofox candidate strategic move",
  "type": "object",
  "additionalProperties": false,
  "required": ["version","candidate_id","product","snapshot_hash","title","strategic_goal","mechanism","assumptions","evidence_record_ids","expected_upside","success_signal","kill_criteria","conversion_plan","scores","exposure","trust_risk","created_by_role","created_at"],
  "properties": {
    "version": {"const": 1},
    "candidate_id": {"type": "string", "pattern": "^MOV-[A-Z0-9-]{6,80}$"},
    "product": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "snapshot_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "title": {"type": "string", "minLength": 3, "maxLength": 160},
    "strategic_goal": {"type": "string", "minLength": 10, "maxLength": 1000},
    "mechanism": {"type": "string", "minLength": 10, "maxLength": 2000},
    "assumptions": {"type": "array", "items": {"type": "string", "minLength": 3, "maxLength": 500}, "uniqueItems": true},
    "evidence_record_ids": {"type": "array", "items": {"type": "string", "pattern": "^(SRC|CLM|ASM|MET)-"}, "uniqueItems": true},
    "expected_upside": {"type": "string", "minLength": 10, "maxLength": 1000},
    "success_signal": {"type": "string", "minLength": 5, "maxLength": 500},
    "kill_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5, "maxLength": 500}, "uniqueItems": true},
    "conversion_plan": {"type": "string", "minLength": 10, "maxLength": 1000},
    "scores": {
      "type": "object", "additionalProperties": false,
      "required": ["constraint_alignment","learning_value","reversibility","execution_feasibility","conversion_readiness"],
      "properties": {
        "constraint_alignment": {"type": "integer", "minimum": 1, "maximum": 5},
        "learning_value": {"type": "integer", "minimum": 1, "maximum": 5},
        "reversibility": {"type": "integer", "minimum": 1, "maximum": 5},
        "execution_feasibility": {"type": "integer", "minimum": 1, "maximum": 5},
        "conversion_readiness": {"type": "integer", "minimum": 1, "maximum": 5}
      }
    },
    "exposure": {
      "type": "object", "additionalProperties": false,
      "required": ["cash_usd","founder_hours","days_to_signal"],
      "properties": {
        "cash_usd": {"type": "number", "minimum": 0},
        "founder_hours": {"type": "number", "minimum": 0},
        "days_to_signal": {"type": "integer", "minimum": 1}
      }
    },
    "trust_risk": {"type": "integer", "minimum": 1, "maximum": 5},
    "created_by_role": {"const": "PLANNER"},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
